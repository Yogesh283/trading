{
  "name": "updownfx",
  "version": "1.0.0",
  "description": "Node.js trading bot scaffold",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:api-only": "cross-env SEPARATE_FRONTEND=1 tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run verify:dist",
    "verify:dist": "node -e \"const fs=require('fs');const p='dist/server.js';if(!fs.existsSync(p)){console.error('missing dist/server.js');process.exit(1)}const s=fs.readFileSync(p,'utf8');if(!s.includes('updownfx-raw')){console.error('dist/server.js missing raw handler — pull latest src from GitHub then npm run build');process.exit(1)}console.log('verify:dist OK');\"",
    "frontend:ci": "npm ci --include=dev --prefix frontend",
    "frontend:install": "npm install --prefix frontend",
    "build:all": "npm run build && npm run frontend:install && npm run frontend:build",
    "build:all:ci": "npm run build && npm run frontend:ci && npm run frontend:build",
    "build:all:local": "npm run build && npm run frontend:build",
    "start": "node dist/index.js",
    "start:live": "npm run build:all && node dist/index.js",
    "free:3000": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/free-port.ps1 -Port 3000",
    "start:live:reset": "npm run free:3000 && npm run start:live",
    "db:create": "tsx src/init-db.ts",
    "db:mysql": "tsx src/init-mysql.ts",
    "lint": "tsc --noEmit",
    "frontend:clear-vite-cache": "node -e \"const fs=require('fs');const p=require('path').join('frontend','node_modules','.vite');try{fs.rmSync(p,{recursive:true,force:true});console.log('Cleared',p);}catch(e){console.log(e.message||e);process.exit(1)}\"",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "cron:investment": "tsx scripts/investment-cron.ts",
    "promote-admin": "tsx scripts/promote-admin.ts",
    "test:live-admin": "tsx scripts/test-live-admin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "otplib": "^13.4.0",
    "pino": "^10.3.1",
    "sqlite3": "^6.0.1",
    "technicalindicators": "^3.1.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^7.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
