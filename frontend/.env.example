# Live / production build: API base URL (no trailing slash)
# Example: VITE_API_URL=https://api.yourdomain.com
# Build: npm run frontend:build — this value is embedded in the bundle.
#
# Agar nginx same domain par /api → Node proxy karta hai (recommended), yahan kuch mat likho
# (khali) taake browser same-origin /api/markets/candles use kare — chart history live par theek chale.
# VITE_API_URL=

# Optional: full URL to your Android APK (landing page “Download APK”). If unset, uses /api/system/android-apk (same origin).
# Production (www primary): VITE_APK_DOWNLOAD_URL=https://www.iqfxpro.com/api/system/android-apk

# Optional: Telegram support / community link (default https://t.me/IQFxP). Must be full https URL.
# VITE_TELEGRAM_URL=https://t.me/IQFxP

# Optional: mirror server demo starting balance for UI labels (must match root .env DEMO_ACCOUNT_DEFAULT_INR).
# VITE_DEMO_ACCOUNT_DEFAULT_INR=10000
