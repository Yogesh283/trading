# Live / production build: API base URL (no trailing slash)
# Example: VITE_API_URL=https://api.yourdomain.com
# Build: npm run frontend:build — this value is embedded in the bundle.
# VITE_API_URL=

# Optional: full URL to your Android APK (landing page “Download APK”). If unset, uses /api/mobile-app (Node-served).
# VITE_APK_DOWNLOAD_URL=https://yourdomain.com/files/UpDownFX.apk
