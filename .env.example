NODE_ENV=development
LOG_LEVEL=info

TRADERMADE_KEY=
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

POSTGRES_URL=
REDIS_URL=redis://localhost:6379
AUTH_SECRET=dev-auth-secret-change-me
PORT=3000
# One command: npm run dev → React + API same PORT (default).
# SEPARATE_FRONTEND=1 → API only; then npm run frontend:dev on 5173

# USDT BEP20 (BSC) — user sends here via MetaMask etc.
USDT_BEP20_DEPOSIT_ADDRESS=0xYourAdminWalletAddressHere
# Optional legacy; admin panel uses JWT + DB role=admin instead.
ADMIN_DEPOSITS_SECRET=
# One-time: promote this registered user's email to admin on server start (then remove from .env).
ADMIN_PROMOTE_EMAIL=

# XAMPP MySQL (optional — leave MYSQL_DATABASE empty to use SQLite data/app.db)
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=tradeing

# Dev: fixed user chrome-live@local.test / LiveEdit1! — see docs/CHROME_LIVE_USER.md
# SEED_CHROME_USER=1

# ---------- Live / Production ----------
# Frontend live API URL: frontend/.env.production mein set karein (build time use hota hai).
# Example: VITE_API_URL=https://api.yourdomain.com  (trailing slash mat rakhein)
# Isse app live server ko hit karega; WebSocket bhi isi URL se connect hoga.
