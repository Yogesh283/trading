NODE_ENV=development
LOG_LEVEL=info

TRADERMADE_KEY=
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

POSTGRES_URL=
REDIS_URL=redis://localhost:6379
AUTH_SECRET=dev-auth-secret-change-me
PORT=3000
# Live wallet: 1 USDT on-chain → this many INR credited (withdraw uses same rate).
# INR_PER_USDT=95

# One command: npm run dev → React + API same PORT (default). No frontend build needed.
# Local: NODE_ENV=development + empty/missing frontend/dist → server auto-attaches Vite (full UI).
# SEPARATE_FRONTEND=1 → API only; then npm run frontend:dev on 5173 (second terminal).

# USDT BEP20 (BSC) — user sends here via MetaMask. Must be 0x + exactly 40 hex chars.
# Leave empty (or delete line) to use built-in dev default — production: set YOUR real BSC address.
USDT_BEP20_DEPOSIT_ADDRESS=0xBF1431c325A7Cba62c741973C058bF5f133A698A
# Optional legacy; admin panel uses JWT + DB role=admin instead.
ADMIN_DEPOSITS_SECRET=0xBF1431c325A7Cba62c741973C058bF5f133A698A
# One-time: promote this registered user's email to admin on server start (then remove from .env).
ADMIN_PROMOTE_EMAIL=

# XAMPP MySQL (optional — leave MYSQL_DATABASE empty to use SQLite data/app.db)
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=tradeing

# Dev: fixed user chrome-live@local.test / LiveEdit1! — see docs/CHROME_LIVE_USER.md
# SEED_CHROME_USER=1

# ---------- Live / Production ----------
# Frontend live API URL: set in frontend/.env.production (used at build time).
# Example: VITE_API_URL=https://api.yourdomain.com  (no trailing slash)
# The app and WebSocket will use this URL to reach the live server.

# Android APK for landing "Download APK" (optional). Full path or path relative to repo root.
# If unset, server uses releases/UpDownFX.apk, then frontend/dist/downloads/, then frontend/public/downloads/
# VPS example (CloudPanel user updowanfx):
# APK_FILE_PATH=/home/updowanfx/htdocs/updowanfx.com/releases/UpDownFX.apk
# APK_FILE_PATH=/var/www/UpDownFX.apk
